# Copy to .env.local and fill in values from Firebase console.
# All VITE_-prefixed vars are exposed to the client bundle.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — Meta Pixel for paid-ads attribution
VITE_META_PIXEL_ID=

# Comma-separated admin allowlist for /admin passwordless sign-in.
# Each entry is either a full email (alex@example.com) OR a bare domain
# (houseoftherisingarts.ca) — domain entries match any email at that
# domain. Anyone can request a magic-link, but only matching addresses
# will actually be granted access (others get auto-signed-out).
VITE_ADMIN_EMAILS=admin@festivalmedievaldemontpellier.org,houseoftherisingarts.ca

# DEV-ONLY: bypass /admin auth entirely + seed mock CRM data so the
# dashboard is viewable without Firebase configured. Leave UNSET in
# production. Setting this to "true" exposes /admin to anyone who knows
# the URL — never deploy with this on.
VITE_ADMIN_DEV_BYPASS=

# Optional — ZEFFY ticketing campaign URL (external CTA from hero)
VITE_ZEFFY_TICKET_URL=https://www.zeffy.com/
# Optional — dedicated Zeffy link for the Behourd 2027 tournament
# registration on the Activités page. Falls back to www.zeffy.com if
# unset so the form still hands off somewhere visible.
VITE_ZEFFY_BEHOURD_URL=

# Discord integration — all optional, section degrades gracefully without them.
# 1. Create an app at https://discord.com/developers/applications
# 2. Copy the Application ID → VITE_DISCORD_CLIENT_ID
# 3. Add redirect URI in OAuth2 → Redirects: https://your-domain/admin
# 4. Enable the server widget in Discord → Server Settings → Widget
# 5. Copy the Server ID → VITE_DISCORD_GUILD_ID
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=https://www.festivalmedievaldemontpellier.org/admin
VITE_DISCORD_GUILD_ID=
VITE_DISCORD_INVITE_URL=

# Site mode — `live` shows the full home; `placeholder` shows the misty
# sword-and-mist teaser. Default `live`.
VITE_SITE_MODE=live

# Header audio player — drop a track URL (e.g. /audio/freyja.mp3) and
# the matching display title. Leave VITE_AUDIO_TRACK_URL empty to hide
# the player.
VITE_AUDIO_TRACK_URL=
VITE_AUDIO_TRACK_TITLE=Freyja — Mystic Projekt

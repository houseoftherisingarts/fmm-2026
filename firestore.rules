rules_version = '2';

// ─── FMM 2026 Firestore security rules ─────────────────────────────
// Strategy:
//   • Each authenticated user owns their /users/{uid}, /benevoles/{uid}
//     and /vendors/{uid} branch.
//   • Admins (email allowlist below) can read & write everything.
//   • The public can read only what's explicitly marked public
//     (accepted vendor list, site flags).
//   • Community wall (posts/dms) is restricted to authenticated users —
//     finer-grained rules can layer in once we move admin to custom
//     claims; for now the email allowlist gates all admin actions.
//
// Keep the email list below in sync with VITE_ADMIN_EMAILS in .env.local
// (full emails) and with any domain entries handled in the client. For
// rules, only full emails are easily expressible; domain entries are
// optional convenience for the *client UI only* and should not be
// trusted on the server side.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'admin@festivalmedievaldemontpellier.org',
          'alex@lesalondesinconnus.com',
          'houseoftherisingarts@gmail.com',
          // Add more admin emails here.
        ];
    }

    // ── Users (profiles) ─────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin() || signedIn();  // public profile fields are readable to signed-in members
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Bénévoles ────────────────────────────────────────────────
    // Owner can submit + edit their application. Admin can read + update
    // status + adminNotes. Bénévole-to-bénévole reads are blocked here
    // because the doc carries private fields (allergies, address, etc).
    // Public profile data is exposed via composePublicProfile in client.
    match /benevoles/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Bénévole ↔ FMM messaging thread
      match /messages/{msgId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if (isOwner(uid) || isAdmin())
                      && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── Vendors (one application per merchant per year) ──────────
    // /vendors/{uid}/years/{year} — owner writes their own; public reads
    // accepted vendors (used by the public marketplace listing).
    match /vendors/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      match /years/{year} {
        allow read: if isOwner(uid) || isAdmin()
                    || resource.data.status == 'accepted';   // public can list approved booths
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isAdmin();
      }

      // Vendor ↔ FMM messaging thread
      match /messages/{msgId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if (isOwner(uid) || isAdmin())
                      && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── Teams ────────────────────────────────────────────────────
    // Read open to any signed-in user; only admins create/edit/delete.
    match /teams/{teamId} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // ── Community wall (posts + comments + reactions + subscribers) ─
    // Open to any signed-in user. Authors can edit/delete their own
    // posts; admins can moderate.
    match /posts/{postId} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin()
                            || (signedIn() && resource.data.authorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read:   if signedIn();
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAdmin()
                              || (signedIn() && resource.data.authorUid == request.auth.uid);
      }
      match /reactions/{uid} {
        allow read: if signedIn();
        allow write: if isOwner(uid);
      }
      match /subscribers/{uid} {
        allow read: if signedIn();
        allow write: if isOwner(uid);
      }
    }

    // ── Direct messages ──────────────────────────────────────────
    // Only the two participants can see / write. Thread id format is
    // the sorted uid pair joined by '__'.
    match /dms/{threadId} {
      allow read:  if signedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
                    && request.auth.uid in request.resource.data.participantUids;
      allow update: if signedIn()
                    && request.auth.uid in resource.data.participantUids;
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if signedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/dms/$(threadId)).data.participantUids;
        allow create: if signedIn()
                      && request.auth.uid == request.resource.data.senderUid
                      && request.auth.uid in get(/databases/$(database)/documents/dms/$(threadId)).data.participantUids;
        allow update, delete: if isAdmin();
      }
    }

    // ── Site flags (vendor open/closed, hero banner toggles) ──────
    match /siteFlags/{doc} {
      allow read:  if true;       // public read — gates public form visibility
      allow write: if isAdmin();
    }

    // ── Musicians (one application per musician per year) ────────
    // /musicians/{uid}/years/{year} — mirrors the vendors layout so
    // a band can have multi-year history. Accepted musicians are
    // publicly listed via composePublicMusician on the client.
    match /musicians/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      match /years/{year} {
        allow read:   if isOwner(uid) || isAdmin()
                      || resource.data.status == 'accepted';
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isAdmin();
      }

      // Musician ↔ FMM messaging thread
      match /messages/{msgId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow create: if (isOwner(uid) || isAdmin())
                      && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ── Admin roles ──────────────────────────────────────────────
    // Pre-provisioned by super-admin, keyed by lowercased email.
    // A signed-in user can read their own role row (so the client UI
    // knows what to enable); only admins can write.
    match /adminRoles/{email} {
      allow read:  if isAdmin()
                   || (signedIn() && request.auth.token.email != null
                       && request.auth.token.email.lower() == email);
      allow write: if isAdmin();
    }

    // ── Admin-only operational collections ───────────────────────
    // bar inventory, volunteer schedule, social-media planner, mail
    // tab (internal — different from inquiry-form `contacts`).
    match /bar/{docId}         { allow read, write: if isAdmin(); }
    match /schedule/{docId}    { allow read, write: if isAdmin(); }
    match /socialPosts/{docId} { allow read, write: if isAdmin(); }

    // ── Public-create, admin-managed inquiry collections ─────────
    // Inquiry / newsletter / contact / behourd forms. Allow create
    // for any visitor; admins read & manage.
    match /mariages/{docId}    { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /chevaux/{docId}     { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /groupes/{docId}     { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /jeunesse/{docId}    { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /contacts/{docId}    { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /newsletter/{docId}  { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /behourd/{docId}     { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /mail/{docId}        { allow create: if true; allow read, update, delete: if isAdmin(); }

    // ── Outgoing email queue (Firebase Extension "Trigger Email") ─
    // Admin-only writes. Each doc dropped here is picked up by the
    // extension and sent via the configured SMTP. We keep public
    // writes blocked to avoid spam — confirmation emails to visitors
    // will go through admin actions (broadcasts) or a future Cloud
    // Function that mirrors form submissions into mail-out.
    match /mail-out/{docId}    { allow read, write: if isAdmin(); }
  }
}
